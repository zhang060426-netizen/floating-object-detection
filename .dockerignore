# Docker build context excludes local/generated artifacts.
.git
.omx
.omx/**
.ccpanes
agent_outputs

# Runtime/local state must be provided by bind mounts or local setup, not baked into images.
runtime/**
storage/**
logs/**
uploads/**
results/**
web-flask/storage/app.sqlite3
web-flask/storage/uploads/**
web-flask/storage/results/**
web-flask/storage/models/**

# Frontend generated/dependency artifacts.
node_modules/**
**/node_modules/**
dist/**
**/dist/**
web-vue/node_modules/**
web-vue/dist/**
web-vue/.vite/**
**/.vite/**

# Python generated/cache artifacts.
__pycache__/**
**/__pycache__/**
.pytest_cache/**
**/.pytest_cache/**
**/*.py[cod]
**/*.pyo
**/*.pyc

# Do not commit or bake model weights in images.
*.pt
*.pth
*.onnx
**/*.pt
**/*.pth
**/*.onnx
**/*.engine
**/*.weights

# Local env files may contain secrets.
*.env
**/.env
**/.env.*.local
web-flask/.env

# OS/editor noise.
**/.DS_Store
