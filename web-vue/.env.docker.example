# Frontend Docker environment example

# Browser-facing API base. Keep /api for nginx same-origin proxy in Docker.
VITE_API_BASE_URL=/api

# Dev-only Vite proxy target for `npm run dev`.
VITE_DEV_PROXY_TARGET=http://localhost:5000

# Nginx runtime upstream inside docker compose network.
# Must match backend compose service name and port.
BACKEND_UPSTREAM=http://backend:5000
